# Production environment variables — copy to .env and fill in real values
# NEVER commit this file with real secrets

# === Secrets (MUST change) ===
JWT_SECRET_KEY=change-me-to-a-random-string
QWEN_API_KEY=your-qwen-api-key

# === Database ===
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_USER=postgres
POSTGRES_DB=newsradar

# === App ===
APP_ENV=production
LOG_LEVEL=INFO

# === CORS ===
CORS_ORIGINS=http://your-server-ip:8084,http://your-domain.com

# === Proxy (optional, remove if not needed) ===
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897

# === Translation ===
TRANSLATION_ENABLED=true